# Cấu hình Google OAuth2
google.client.id=ĐIỀN_CLIENT_ID_VÀO_ĐÂY
google.client.secret=ĐIỀN_CLIENT_SECRET_VÀO_ĐÂY

# Cấu hình SMTP
smtp.host=smtp.gmail.com
smtp.port=587
smtp.user=your-email@gmail.com
smtp.password=your-app-password

# Cấu hình SePay (https://my.sepay.vn)
# Điền giá trị thật vào src/main/resources/config.properties (file đó đã gitignore).
# Số tài khoản nhận tiền: lấy tham số "acc" trong mục "Mã nhúng QR" trên my.sepay.vn
# (với tài khoản ảo VA thì là mã VA, vd 96247xxxxIW, KHÔNG phải số tài khoản gốc)
sepay.bank.account=DIEN_ACC_TU_MA_NHUNG_QR
# Tên ngân hàng theo chuẩn SePay/VietQR (vd: BIDV, MBBank, ACB, VPBank...)
sepay.bank.code=BIDV
# Tên chủ tài khoản hiển thị trên mã QR (viết hoa không dấu, theo mã nhúng)
sepay.account.holder=NGUYEN VAN A
# API Key tự đặt, phải trùng với API Key khai báo ở Webhook trên my.sepay.vn
sepay.webhook.apikey=DIEN_CHUOI_NGAU_NHIEN_DAI_VAO_DAY
# Tiền tố nội dung chuyển khoản để nhận diện hóa đơn (HD123 = hóa đơn 123)
sepay.payment.prefix=HD
# Tiền tố nội dung chuyển khoản tiền cọc đặt phòng (COC45 = cọc đặt phòng 45)
sepay.deposit.prefix=COC

